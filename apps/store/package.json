{
  "name": "@printflow/store",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "npx expo start",
    "start:clear": "npx expo start --clear",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "eas:android:preview": "npx eas build --platform android --profile preview",
    "eas:ios:preview": "npx eas build --platform ios --profile preview",
    "eas:android:production": "npx eas build --platform android --profile production",
    "eas:ios:production": "npx eas build --platform ios --profile production",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@printflow/shared": "file:../../packages/shared",
    "expo": "~52.0.49",
    "expo-build-properties": "~0.13.3",
    "expo-splash-screen": "~0.29.0",
    "react": "^18.3.1",
    "react-native": "^0.76.9"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.6.3"
  }
}
